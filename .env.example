# ============================================================
# サーバ側 (server/.env) で使用する環境変数
# ============================================================

# ラズパイのベースURL（GPS・温度 両方で使用）
RASPI_BASE_URL=http://100.x.x.x:8080

# GPS APIの完全URL（RASPI_BASE_URLから自動生成されるが上書き可）
RASPI_GPS_URL=http://100.x.x.x:8080/gps

# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=<your-slack-incoming-webhook-url>

# ポーリング間隔（秒）デフォルト: 60
POLL_INTERVAL_SECONDS=60

# 同一位置でのアラート再通知クールダウン（秒）デフォルト: 1800（30分）
NOTIFY_COOLDOWN_SECONDS=1800

# この距離（メートル）以上移動したら即時再通知 デフォルト: 200
NOTIFY_MOVE_THRESHOLD_M=200

# ラズパイへのリクエストタイムアウト（秒）デフォルト: 15
REQUEST_TIMEOUT_SECONDS=15

# 地図WebUIのポート デフォルト: 8081
# WEB_PORT=8081

# 温度ポーリング間隔（秒）デフォルト: 300（5分）
# TEMP_POLL_INTERVAL_SECONDS=300

# ============================================================
# ラズパイ側 (raspberry/.env) で使用する環境変数
# ============================================================

# gpsdのホスト・ポート（通常は変更不要）
# GPSD_HOST=localhost
# GPSD_PORT=2947

# APIサーバのバインドアドレス・ポート
# API_HOST=0.0.0.0
# API_PORT=8080

# GPS未取得が続いた場合にキャッシュを無効化するまでの秒数（デフォルト: 86400=1日）
# CACHE_MAX_AGE_SECONDS=86400
